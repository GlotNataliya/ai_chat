<div class="layout-container flex h-full grow flex-col items-center justify-center p-4">
  <%= render "shared/header_login" %>

  <div class="w-full max-w-[480px] bg-white dark:bg-slate-900/50 p-8 rounded-xl shadow-sm border border-primary/10">
    <div class="text-center mb-8">
      <h1 class="text-slate-900 dark:text-white text-3xl font-bold leading-tight mb-2">Create new password</h1>
      <p class="text-slate-500 dark:text-slate-400 text-base">Enter your new password below</p>
    </div>

    <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-5" do |form| %>
      <% if @user && @user.errors.any? %>
        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl relative mb-4">
          <ul class="list-disc list-inside text-sm">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex flex-col gap-2">
        <%= form.label :password, "New password", class: "text-slate-700 dark:text-slate-300 text-sm font-semibold" %>
        <div class="relative" data-controller="password-visibility">
          <%= form.password_field :password,
              placeholder: "Enter your new password",
              class: "w-full rounded-xl border border-primary/20 bg-primary/5 px-4 py-3.5 text-slate-900 dark:text-white placeholder:text-slate-400 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all",
              required: true,
              maxlength: 72,
              data: { password_visibility_target: "input" } %>
          <button type="button"
                  class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-primary"
                  data-action="click->password-visibility#toggle">
            <span class="material-symbols-outlined" data-password-visibility-target="icon">
              visibility
            </span>
          </button>
        </div>
        <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">Minimum 6 characters</p>
      </div>

      <div class="flex flex-col gap-2">
        <%= form.label :password_confirmation, "Confirm new password", class: "text-slate-700 dark:text-slate-300 text-sm font-semibold" %>
        <div class="relative" data-controller="password-visibility">
          <%= form.password_field :password_confirmation,
              placeholder: "Confirm your new password",
              class: "w-full rounded-xl border border-primary/20 bg-primary/5 px-4 py-3.5 text-slate-900 dark:text-white placeholder:text-slate-400 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all",
              required: true,
              maxlength: 72,
              data: { password_visibility_target: "input" } %>
          <button type="button"
                  class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-primary"
                  data-action="click->password-visibility#toggle">
            <span class="material-symbols-outlined" data-password-visibility-target="icon">
              visibility
            </span>
          </button>
        </div>
      </div>

      <%= form.submit "Reset password",
          class: "w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/20 transition-all active:scale-[0.98] cursor-pointer mt-6" %>
    <% end %>

    <div class="mt-6 text-center">
      <%= link_to new_session_path, class: "text-slate-600 dark:text-slate-400 hover:text-primary text-sm inline-flex items-center gap-1 transition-colors" do %>
        <span class="material-symbols-outlined text-base">arrow_back</span>
        <span>Back to sign in</span>
      <% end %>
    </div>
  </div>
</div>
