<!-- app/views/registrations/new.html.erb -->
<div class="layout-container flex h-full grow flex-col items-center justify-center p-4">
  <%= render "shared/header_login" %>

  <div class="w-full max-w-[480px] bg-white dark:bg-slate-900/50 p-8 rounded-xl shadow-sm border border-primary/10">
    <div class="text-center mb-8">
      <h1 class="text-slate-900 dark:text-white text-3xl font-bold leading-tight mb-2">Create Account</h1>
      <p class="text-slate-500 dark:text-slate-400 text-base">Sign up to start your conversations</p>
    </div>

    <%= form_with model: @user, url: registrations_path, local: true, class: "space-y-5" do |form| %>
      <% if @user.errors.any? %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
          <ul class="list-disc list-inside">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex flex-col gap-2">
        <%= form.label :email, class: "text-slate-700 dark:text-slate-300 text-sm font-semibold" %>
        <%= form.email_field :email_address,
            placeholder: "name@example.com",
            class: "w-full rounded-xl border border-primary/20 bg-primary/5 px-4 py-3.5 text-slate-900 dark:text-white placeholder:text-slate-400 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all",
            required: true %>
      </div>

      <div class="flex flex-col gap-2">
        <%= form.label :password, class: "text-slate-700 dark:text-slate-300 text-sm font-semibold" %>
        <%= form.password_field :password,
            placeholder: "Create password (min. 6 characters)",
            class: "w-full rounded-xl border border-primary/20 bg-primary/5 px-4 py-3.5 text-slate-900 dark:text-white placeholder:text-slate-400 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all",
            required: true %>
      </div>

      <div class="flex flex-col gap-2">
        <%= form.label :password_confirmation, "Confirm Password", class: "text-slate-700 dark:text-slate-300 text-sm font-semibold" %>
        <%= form.password_field :password_confirmation,
            placeholder: "Confirm your password",
            class: "w-full rounded-xl border border-primary/20 bg-primary/5 px-4 py-3.5 text-slate-900 dark:text-white placeholder:text-slate-400 focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all",
            required: true %>
      </div>

      <%= form.submit "Sign Up",
          class: "w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 rounded-xl shadow-lg shadow-primary/20 transition-all active:scale-[0.98] cursor-pointer" %>
    <% end %>

    <p class="mt-8 text-center text-sm text-slate-500 dark:text-slate-400">
      Already have an account?
      <%= link_to "Sign in", new_session_path, class: "text-primary font-bold hover:underline" %>
    </p>
  </div>

  <footer class="mt-8 text-slate-400 text-xs">
    <div class="flex gap-4">
      <%= link_to "Privacy Policy", "#", class: "hover:text-primary" %>
      <%= link_to "Terms of Service", "#", class: "hover:text-primary" %>
    </div>
  </footer>
</div>
